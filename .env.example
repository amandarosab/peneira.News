# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório!

# Chave secreta do Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# API Key da OpenAI (opcional — sem ela, resumos usam fallback de texto simples)
OPENAI_API_KEY=

# Se estiver rodando na Vercel, esta variável é setada automaticamente
# VERCEL=1
