# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório!

# Chave secreta do Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# API Key da OpenAI (opcional — sem ela, resumos usam fallback de texto simples)
OPENAI_API_KEY=

# Armazenamento privado dos formulários
PRIVATE_STORAGE_ID=
PRIVATE_STORAGE_CREDENTIALS_FILE=private_storage_credentials.json
# Em deploy na Vercel, prefira usar JSON inline como Environment Variable.
# Se PRIVATE_STORAGE_ID + credenciais não estiverem configurados na Vercel,
# o envio agora falha explicitamente para evitar falso positivo com /tmp.
# PRIVATE_STORAGE_CREDENTIALS_JSON={"type":"service_account",...}
# PRIVATE_STORAGE_TAB_SUGGESTIONS=Sugestoes
# PRIVATE_STORAGE_TAB_CONTACT=Contato
# Opcional e não recomendado: permite fallback temporário em /tmp na Vercel
# PRIVATE_STORAGE_ALLOW_VERCEL_LOCAL_FALLBACK=1

# Token opcional para proteger o endpoint GET /api/diagnostico/storage
# Em produção, configure e envie no header X-Diagnostic-Token.
# STORAGE_DIAGNOSTIC_TOKEN=

# Se estiver rodando na Vercel, esta variável é setada automaticamente
# VERCEL=1
